# Server runtime
PORT=5000
# A long random string is required in production. The server refuses to start
# without this when NODE_ENV=production. Generate one with e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-value

# PostgreSQL connection (required for persistent storage on Vercel/Render).
# When unset, the server falls back to in-memory storage (dev/test only).
# Neon HTTP example:
#   postgresql://user:pass@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Notes:
# - TEAM_IDs (TEAM01, TEAM02, ...) are auto-generated by the server on user
#   registration via a Postgres sequence. There is no admin bootstrap value to
#   provide; older deployments that set ADMIN_BOOTSTRAP_TEAM_ID can drop it.

# Optional: Google Gemini API for the in-app help bot.
# - When unset, the bot answers from a small local FAQ (TEAM_ID, NEXUS, etc.).
# - When set, the bot calls Gemini (defaults to "gemini-2.5-flash"). Get a key
#   at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional override for the model id; defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
